-- UPDATE CRYSTAL LIST GUI
-- ==========================================

local function updateCrystalListGUI()
    if not scrollFrame then return end

    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end

    if not espEnabled or not crystalListEnabled then
        if crystalListGui then
            crystalListGui.Enabled = false
        end
        return
    end

    if crystalListGui then
        crystalListGui.Enabled = true
    end

    local crystals = getAllCrystals()
    local filtered = {}
    local playerPos = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")

    if not playerPos then return end

    for _, crystal in ipairs(crystals) do
        local targetPart = crystal:IsA("BasePart") and crystal or crystal:FindFirstChildWhichIsA("BasePart")
        if targetPart then
            local dist = (targetPart.Position - playerPos.Position).Magnitude
            if dist <= espMaxDistance then
                local tierName = crystal:GetAttribute("TierName")
                if not tierName then
                    local tierNum = crystal:GetAttribute("Tier")
                    if tierNum then
                        local tierNames = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythic"}
                        tierName = tierNames[(tierNum + 1)]
                    end
                end

                if selectedRarity == "All" or tierName == selectedRarity then
                    local value = crystal:GetAttribute("Value") or 0
                    table.insert(filtered, {
                        crystal = crystal,
                        tierName = tierName or "Unknown",
                        value = value,
                        weight = crystal:GetAttribute("WeightKg") or 0,
                        distance = dist,
                        name = crystal:GetAttribute("CrystalName") or crystal.Name
                    })
                end
            end
        end
    end

    table.sort(filtered, function(a, b) return a.value > b.value end)

    if #filtered > 30 then
        for i = 31, #filtered do
            table.remove(filtered, i)
        end
    end

    if #filtered == 0 then
        local emptyFrame = Instance.new("Frame")
        emptyFrame.Size = UDim2.new(1, 0, 1, 0)
        emptyFrame.BackgroundTransparency = 1
        emptyFrame.Parent = scrollFrame

        local emptyText = Instance.new("TextLabel")
        emptyText.Size = UDim2.new(1, -4, 0, 50)
        emptyText.Position = UDim2.new(0, 2, 0.5, -25)
        emptyText.BackgroundTransparency = 1
        if selectedRarity == "All" then
            emptyText.Text = "No crystals found on the server,\ntry waiting for a new Mountain or hopping!"
        else
            emptyText.Text = "No " .. selectedRarity .. "s found on the server,\ntry waiting for a new Mountain or hopping!"
        end
        emptyText.TextColor3 = Color3.fromRGB(180, 180, 180)
        emptyText.Font = Enum.Font.Gotham
        emptyText.TextSize = 9
        emptyText.TextWrapped = true
        emptyText.Parent = emptyFrame
        return
    end

    for _, data in ipairs(filtered) do
        local color = monoColors[data.tierName] or Color3.fromRGB(200, 200, 200)

        local entry = Instance.new("Frame")
        entry.Size = UDim2.new(1, 0, 0, 34)
        entry.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        entry.BackgroundTransparency = 0.3
        entry.Parent = scrollFrame

        local entryCorner = Instance.new("UICorner")
        entryCorner.CornerRadius = UDim.new(0, 2)
        entryCorner.Parent = entry

        local border = Instance.new("UIStroke")
        border.Color = Color3.fromRGB(40, 40, 40)
        border.Thickness = 0.5
        border.Transparency = 0.5
        border.Parent = entry

        local line1 = Instance.new("TextLabel")
        line1.Size = UDim2.new(1, -4, 0, 16)
        line1.Position = UDim2.new(0, 2, 0, 1)
        line1.BackgroundTransparency = 1
        line1.Font = Enum.Font.GothamBold
        line1.TextSize = 9
        line1.Text = "[" .. data.name .. "] / ["
        line1.TextColor3 = Color3.fromRGB(200, 200, 200)
        line1.TextXAlignment = Enum.TextXAlignment.Left
        line1.TextYAlignment = Enum.TextYAlignment.Center
        line1.Parent = entry

        local tierPart = Instance.new("TextLabel")
        tierPart.Size = UDim2.new(0, #data.tierName * 5.5 + 2, 0, 16)
        tierPart.Position = UDim2.new(0, (#data.name + 7) * 5.5 + 2, 0, 1)
        tierPart.BackgroundTransparency = 1
        tierPart.Font = Enum.Font.GothamBold
        tierPart.TextSize = 9
        tierPart.Text = data.tierName .. "]"
        tierPart.TextColor3 = color
        tierPart.TextXAlignment = Enum.TextXAlignment.Left
        tierPart.TextYAlignment = Enum.TextYAlignment.Center
        tierPart.Parent = entry

        local divider = Instance.new("Frame")
        divider.Size = UDim2.new(1, -4, 0, 1)
        divider.Position = UDim2.new(0, 2, 0, 17)
        divider.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        divider.BackgroundTransparency = 0.3
        divider.BorderSizePixel = 0
        divider.Parent = entry

        local line2 = Instance.new("TextLabel")
        line2.Size = UDim2.new(1, -4, 0, 14)
        line2.Position = UDim2.new(0, 2, 0, 18)
        line2.BackgroundTransparency = 1
        line2.Font = Enum.Font.GothamBold
        line2.TextSize = 8
        line2.Text = "[" .. formatNumber(data.value) .. "] / [" .. string.format("%.1f", data.weight) .. "kg] / [" .. string.format("%.0f", data.distance) .. "]"
        line2.TextColor3 = Color3.fromRGB(180, 180, 180)
        line2.TextXAlignment = Enum.TextXAlignment.Left
        line2.TextYAlignment = Enum.TextYAlignment.Center
        line2.Parent = entry

        local clickBtn = Instance.new("TextButton")
        clickBtn.Size = UDim2.new(1, 0, 1, 0)
        clickBtn.BackgroundTransparency = 1
        clickBtn.Text = ""
        clickBtn.Parent = entry

        clickBtn.MouseButton1Click:Connect(function()
            local targetPart = data.crystal:IsA("BasePart") and data.crystal or data.crystal:FindFirstChildWhichIsA("BasePart")
