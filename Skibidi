                local root = localPlayer.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 3, 0))
                    teleportedCrystal = data.crystal
                    if teleportedHighlight and teleportedHighlight.Parent then
                        teleportedHighlight:Destroy()
                        teleportedHighlight = nil
                    end
                    -- Create platform under player
                    createPlatform()
                    applyESP()
                end
            end
        end)

        clickBtn.MouseEnter:Connect(function()
            entry.BackgroundTransparency = 0.1
        end)

        clickBtn.MouseLeave:Connect(function()
            entry.BackgroundTransparency = 0.3
        end)
    end
end

-- ==========================================
-- APPLY ESP
-- ==========================================

local function applyESP()
    clearESP()

    if not espEnabled then 
        if crystalListGui then crystalListGui.Enabled = false end
        return 
    end

    local crystals = getAllCrystals()
    if #crystals == 0 then
        Library:Notify({
            Title = "ESP",
            Description = "No crystals found!",
            Time = 3
        })
        return
    end

    local count = 0
    local playerPos = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")

    for _, crystal in ipairs(crystals) do
        local targetPart = crystal:IsA("BasePart") and crystal or crystal:FindFirstChildWhichIsA("BasePart")
        if targetPart then
            local dist = playerPos and (targetPart.Position - playerPos.Position).Magnitude or 0

            if dist <= espMaxDistance then
                local tierName = crystal:GetAttribute("TierName")
                if not tierName then
                    local tierNum = crystal:GetAttribute("Tier")
                    if tierNum then
                        local tierNames = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythic"}
                        tierName = tierNames[(tierNum + 1)]
                    end
                end

                if selectedRarity == "All" or tierName == selectedRarity then
                    attachTextESP(crystal, tierName or "Unknown")
                    count = count + 1
                end
            end
        end
    end

    if crystalListEnabled then
        createCrystalListGUI()
        updateCrystalListGUI()
    end

    Library:Notify({
        Title = "ESP",
        Description = "Showing " .. count .. " " .. selectedRarity .. " crystals",
        Time = 3
    })
end

