-- Format numbers
local function formatNumber(num)
    if not num then return "0" end
    if num >= 1e9 then return string.format("%.1fB", num / 1e9) end
    if num >= 1e6 then return string.format("%.1fM", num / 1e6) end
    if num >= 1e3 then return string.format("%.1fK", num / 1e3) end
    return tostring(num)
end

-- Get all crystals
local function getAllCrystals()
    local list = {}

    -- Try all possible crystal locations
    local possiblePaths = {
        Workspace:FindFirstChild("Things") and Workspace:FindFirstChild("Things"):FindFirstChild("Crystals"),
        Workspace:FindFirstChild("Crystals"),
        Workspace:FindFirstChild("Dropped Crystals"),
        Workspace:FindFirstChild("DroppedCrystals"),
        Workspace:FindFirstChild("Dropped"),
        Workspace:FindFirstChild("Drop"),
        Workspace:FindFirstChild("GroundCrystals"),
        Workspace:FindFirstChild("FloorCrystals"),
        Workspace:FindFirstChild("Resources") and Workspace:FindFirstChild("Resources"):FindFirstChild("Crystals"),
    }

    for _, folder in ipairs(possiblePaths) do
        if folder then
            for _, c in ipairs(folder:GetChildren()) do
                if c:GetAttribute("CrystalName") then
                    table.insert(list, c)
                end
            end
        end
    end

    -- Fallback: find any part with CrystalName attribute or Tier attribute
    if #list == 0 then
        local allParts = Workspace:GetDescendants()
        for _, obj in ipairs(allParts) do
            if obj:IsA("BasePart") then
                local hasCrystalName = obj:GetAttribute("CrystalName")
                local hasTier = obj:GetAttribute("Tier")
                local hasTierName = obj:GetAttribute("TierName")
                if hasCrystalName or hasTier or hasTierName then
                    table.insert(list, obj)
                end
            end
        end
    end

    return list
end

-- Get text width for underline
local function getTextWidth(text, textSize)
    local charWidth = textSize * 0.55
    return #text * charWidth
end

-- Clear ESP visuals (billboards + highlights)
local function clearESP()
    for _, bb in ipairs(activeBillboards) do
        if bb and bb.Parent then bb:Destroy() end
    end
    for _, hl in ipairs(activeHighlights) do
        if hl and hl.Parent then hl:Destroy() end
    end
    if teleportedHighlight and teleportedHighlight.Parent then
        teleportedHighlight:Destroy()
    end
    activeBillboards = {}
    activeHighlights = {}
    teleportedHighlight = nil
end

-- Remove platform
local function removePlatform()
    if currentPlatform then
        if currentPlatform.Parent then
            currentPlatform:Destroy()
        end
        currentPlatform = nil
    end
    if platformWeld then
        platformWeld:Destroy()
        platformWeld = nil
    end
    if platformButton then
        platformButton.Visible = false
    end
end

-- Create platform under player
local function createPlatform()
    -- Remove any existing platform
    removePlatform()
    
    local char = localPlayer.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Create a transparent platform
    local platform = Instance.new("Part")
    platform.Size = Vector3.new(8, 0.5, 8)
    platform.Material = Enum.Material.SmoothPlastic
    platform.BrickColor = BrickColor.new("White")
    platform.Transparency = 0.5
    platform.Anchored = false
    platform.CanCollide = true
    platform.Name = "TeleportPlatform"
    platform.Parent = Workspace
    
    -- Position it under the player's feet
    local pos = root.Position - Vector3.new(0, root.Size.Y/2 + 0.25, 0)
    platform.Position = pos
    
    -- Weld it to the root part so it moves with the player
    local weld = Instance.new("Weld")
    weld.Part0 = root
    weld.Part1 = platform
    weld.C0 = CFrame.new(0, -root.Size.Y/2 - 0.25, 0)
    weld.Parent = platform
    
    currentPlatform = platform
    platformWeld = weld
    
    -- Show the remove button
    if platformButton then
        platformButton.Visible = true
    end
end

-- Attach box highlight for teleported crystal
local function attachBoxESP(crystal)
    local targetPart = crystal:IsA("BasePart") and crystal or crystal:FindFirstChildWhichIsA("BasePart")
    if not targetPart then return end

    if teleportedHighlight and teleportedHighlight.Parent then
        teleportedHighlight:Destroy()
    end

    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.7
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = targetPart
    highlight.Parent = crystal
    teleportedHighlight = highlight
    teleportedCrystal = crystal
end

-- Attach normal highlight + billboard
local function attachTextESP(crystal, tierName)
    local targetPart = crystal:IsA("BasePart") and crystal or crystal:FindFirstChildWhichIsA("BasePart")
    if not targetPart then return end

    -- Check if this is the teleported crystal
    if crystal == teleportedCrystal then
        attachBoxESP(crystal)
    else
        local color = tierColors[tierName] or Color3.fromRGB(255, 255, 255)
        local highlight = Instance.new("Highlight")
        highlight.FillColor = color
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.4
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = crystal
        table.insert(activeHighlights, highlight)
    end

    -- Billboard (same for all)
    local color = tierColors[tierName] or Color3.fromRGB(255, 255, 255)
    local cName = crystal:GetAttribute("CrystalName") or crystal.Name
    local value = crystal:GetAttribute("Value") or 0
    local weight = crystal:GetAttribute("WeightKg") or 0

    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 300, 0, 80)
    billboard.AlwaysOnTop = true
    billboard.StudsOffset = Vector3.new(0, 4, 0)
    billboard.Adornee = targetPart
    billboard.MaxDistance = espMaxDistance
    billboard.Parent = targetPart
    table.insert(activeBillboards, billboard)

    -- Line 1: [Name] / [Tier]
    local line1 = Instance.new("TextLabel")
    line1.Size = UDim2.new(1, 0, 0, 24)
    line1.Position = UDim2.new(0, 0, 0, 0)
    line1.BackgroundTransparency = 1
    line1.Font = Enum.Font.GothamBold
    line1.TextSize = 14
    line1.Text = "[" .. cName .. "] / [" .. tierName .. "]"
    line1.TextColor3 = color
    line1.TextXAlignment = Enum.TextXAlignment.Right
    line1.TextYAlignment = Enum.TextYAlignment.Center
    line1.Parent = billboard

    local underline1 = Instance.new("Frame")
    underline1.Size = UDim2.new(0, getTextWidth(line1.Text, 14), 0, 2)
    underline1.Position = UDim2.new(1, -getTextWidth(line1.Text, 14), 0, 24)
    underline1.BackgroundColor3 = color
    underline1.BackgroundTransparency = 0.3
    underline1.BorderSizePixel = 0
    underline1.Parent = billboard

    -- Line 2: [Value] / [Weight] / [Distance]
    local line2 = Instance.new("TextLabel")
    line2.Size = UDim2.new(1, 0, 0, 20)
    line2.Position = UDim2.new(0, 0, 0, 28)
    line2.BackgroundTransparency = 1
    line2.Font = Enum.Font.GothamBold
    line2.TextSize = 12
    line2.TextColor3 = Color3.fromRGB(255, 255, 255)
    line2.TextXAlignment = Enum.TextXAlignment.Right
    line2.TextYAlignment = Enum.TextYAlignment.Center
    line2.Parent = billboard

    local underline2 = Instance.new("Frame")
    underline2.Size = UDim2.new(0, 1, 0, 2)
    underline2.Position = UDim2.new(1, 0, 0, 50)
    underline2.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    underline2.BackgroundTransparency = 0.2
    underline2.BorderSizePixel = 0
    underline2.Parent = billboard

    -- Update distance
    task.spawn(function()
        while billboard and billboard.Parent and scriptRunning do
            local char = localPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local distance = "0"

            if root then
                local dist = (targetPart.Position - root.Position).Magnitude
                distance = string.format("%.0f", dist)
            end

            local valueText = "[" .. formatNumber(value) .. "] / [" .. string.format("%.1f", weight) .. "kg] / [" .. distance .. "]"
            line2.Text = valueText

            local width2 = getTextWidth(valueText, 12)
            underline2.Size = UDim2.new(0, width2, 0, 2)
            underline2.Position = UDim2.new(1, -width2, 0, 50)

            task.wait(0.15)
        end
    end)
end

