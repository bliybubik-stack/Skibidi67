-- Create platform under player
local function createPlatform()
    removePlatform()
    
    if not platformEnabled then return end
    
    local char = localPlayer.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    platformY = root.Position.Y + platformOffset
    
    platform = Instance.new("Part")
    platform.Size = Vector3.new(12, 1, 12)
    platform.Anchored = true
    platform.CanCollide = true
    platform.Material = Enum.Material.SmoothPlastic
    platform.BrickColor = BrickColor.new("White")
    platform.Transparency = 0.5
    platform.Name = "TeleportPlatform"
    platform.Position = Vector3.new(root.Position.X, platformY, root.Position.Z)
    platform.Parent = Workspace
    
    platformConnection = RunService.Heartbeat:Connect(function()
        if platform and root then
            platform.Position = Vector3.new(root.Position.X, platformY, root.Position.Z)
        end
    end)
    
    if platformButtonFrame then
        platformButtonFrame.Visible = true
    end
    if removePlatformButton then
        removePlatformButton.Visible = true
    end
end

-- Teleport to crystal and highlight it
local function teleportToCrystal(crystal)
    if not crystal then return false end
    
    local targetPart = crystal:IsA("BasePart") and crystal or crystal:FindFirstChildWhichIsA("BasePart")
    if not targetPart then return false end
    
    local char = localPlayer.Character
    if not char then return false end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    
    root.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 3, 0))
    teleportedCrystal = crystal
    
    if teleportedHighlight and teleportedHighlight.Parent then
        teleportedHighlight:Destroy()
        teleportedHighlight = nil
    end
    
    -- Create box highlight for teleported crystal
    local highlight = Instance.new("Highlight")
    highlight.FillColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = targetPart
    highlight.Parent = crystal
    teleportedHighlight = highlight
    
    if platformEnabled then
        createPlatform()
    end
    
    if espEnabled then
        applyESP()
    end
    
    return true
end

-- Find best crystal based on criteria
local function findBestCrystal(minValue, preferredTier, minDistance, maxDistance)
    local crystals = getAllCrystals()
    if #crystals == 0 then return nil end
    
    local playerPos = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not playerPos then return nil end
    
    local bestCrystal = nil
    local bestValue = -1
    
    local tierPriority = {
        ["All"] = nil,
        ["Common"] = 0,
        ["Uncommon"] = 1,
        ["Rare"] = 2,
        ["Epic"] = 3,
        ["Legendary"] = 4,
        ["Mythic"] = 5,
    }
    local targetTier = tierPriority[preferredTier]
    
    for _, crystal in ipairs(crystals) do
        local targetPart = crystal:IsA("BasePart") and crystal or crystal:FindFirstChildWhichIsA("BasePart")
        if targetPart then
            local dist = (targetPart.Position - playerPos.Position).Magnitude
            
            if maxDistance and dist > maxDistance then continue end
            if dist < minDistance then continue end
            
            local tierName = crystal:GetAttribute("TierName")
            if not tierName then
                local tierNum = crystal:GetAttribute("Tier")
                if tierNum then
                    local tierNames = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythic"}
                    tierName = tierNames[(tierNum + 1)]
                end
            end
            
            if targetTier ~= nil then
                local crystalTier = tierPriority[tierName]
                if crystalTier == nil or crystalTier ~= targetTier then
                    continue
                end
            end
            
            local value = crystal:GetAttribute("Value") or 0
            if value < minValue then continue end
            
            if value > bestValue then
                bestValue = value
                bestCrystal = crystal
            end
        end
    end
    
    return bestCrystal
end

-- TP to Best function
local function tpToBest()
    local bestCrystal = findBestCrystal(tpMinValue, tpPreferredTier, tpMinDistance, espEnabled and espMaxDistance or math.huge)
    
    if bestCrystal then
        if teleportToCrystal(bestCrystal) then
            local tierName = bestCrystal:GetAttribute("TierName") or "Unknown"
            local value = bestCrystal:GetAttribute("Value") or 0
            Library:Notify({
                Title = "TP to Best",
                Description = "Teleported to " .. tierName .. " (Value: " .. formatNumber(value) .. ")",
                Time = 3
            })
        end
    else
        local tierDisplay = tpPreferredTier
        if tierDisplay == "All" then
            Library:Notify({
                Title = "TP to Best",
                Description = "No crystals match your criteria!",
                Time = 3
            })
        else
            Library:Notify({
                Title = "TP to Best",
                Description = "No " .. tierDisplay .. " crystals match your criteria!",
                Time = 3
            })
        end
    end
end

-- Auto Farm function
local function autoFarmCycle()
    if not autoFarmEnabled then return end
    
    local bestCrystal = findBestCrystal(autoFarmMinValue, autoFarmPreferredTier, autoFarmMinDistance, espEnabled and espMaxDistance or math.huge)
    
    if bestCrystal then
        if teleportToCrystal(bestCrystal) then
            local tierName = bestCrystal:GetAttribute("TierName") or "Unknown"
            local value = bestCrystal:GetAttribute("Value") or 0
            Library:Notify({
                Title = "Auto Farm",
                Description = "Teleported to " .. tierName .. " (Value: " .. formatNumber(value) .. ")",
                Time = 2
            })
        end
    else
        Library:Notify({
            Title = "Auto Farm",
            Description = "No crystals match your criteria! Stopping.",
            Time = 3
        })
        autoFarmEnabled = false
        if Toggles and Toggles.AutoFarmToggle then
            Toggles.AutoFarmToggle:SetValue(false)
        end
    end
end

-- Start/Stop Auto Farm
local function toggleAutoFarm(value)
    autoFarmEnabled = value
    if autoFarmLoop then
        autoFarmLoop:Disconnect()
        autoFarmLoop = nil
    end
    if value then
        autoFarmLoop = RunService.Heartbeat:Connect(function()
            if autoFarmEnabled then
                autoFarmCycle()
                task.wait(autoFarmDelay)
            end
        end)
    end
end

