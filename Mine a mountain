-- Format numbers
local function formatNumber(num)
    if not num then return "0" end
    if num >= 1e9 then return string.format("%.1fB", num / 1e9) end
    if num >= 1e6 then return string.format("%.1fM", num / 1e6) end
    if num >= 1e3 then return string.format("%.1fK", num / 1e3) end
    return tostring(num)
end

-- Get all crystals
local function getAllCrystals()
    local list = {}

    -- Try all possible crystal locations
    local possiblePaths = {
        Workspace:FindFirstChild("Things") and Workspace:FindFirstChild("Things"):FindFirstChild("Crystals"),
        Workspace:FindFirstChild("Crystals"),
        Workspace:FindFirstChild("Dropped Crystals"),
        Workspace:FindFirstChild("DroppedCrystals"),
        Workspace:FindFirstChild("Dropped"),
        Workspace:FindFirstChild("Drop"),
        Workspace:FindFirstChild("GroundCrystals"),
        Workspace:FindFirstChild("FloorCrystals"),
        Workspace:FindFirstChild("Resources") and Workspace:FindFirstChild("Resources"):FindFirstChild("Crystals"),
    }

    for _, folder in ipairs(possiblePaths) do
        if folder then
            for _, c in ipairs(folder:GetChildren()) do
                if c:GetAttribute("CrystalName") then
                    table.insert(list, c)
                end
            end
        end
    end

    -- Fallback: find any part with CrystalName attribute or Tier attribute
    if #list == 0 then
        local allParts = Workspace:GetDescendants()
        for _, obj in ipairs(allParts) do
            if obj:IsA("BasePart") then
                local hasCrystalName = obj:GetAttribute("CrystalName")
                local hasTier = obj:GetAttribute("Tier")
                local hasTierName = obj:GetAttribute("TierName")
                if hasCrystalName or hasTier or hasTierName then
                    table.insert(list, obj)
                end
            end
        end
    end

    return list
end

-- Get text width for underline
local function getTextWidth(text, textSize)
    local charWidth = textSize * 0.55
    return #text * charWidth
end

-- Clear ESP visuals (billboards + highlights)
