local function updateCrystalListGUI()
    if not scrollFrame then return end

    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end

    if not espEnabled or not crystalListEnabled then
        if crystalListGui then
            crystalListGui.Enabled = false
        end
        return
    end

    if crystalListGui then
        crystalListGui.Enabled = true
    end

    local crystals = getAllCrystals()
    local filtered = {}
    local playerPos = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart")

    if not playerPos then return end

    for _, crystal in ipairs(crystals) do
        local targetPart = crystal:IsA("BasePart") and crystal or crystal:FindFirstChildWhichIsA("BasePart")
        if targetPart then
            local dist = (targetPart.Position - playerPos.Position).Magnitude
            if dist <= espMaxDistance then
                local tierName = crystal:GetAttribute("TierName")
